# Монорепозиторий Expansion: в git — expansion_app/, expansion_server/, expansion_admin/, docs/, .cursor/, AGENTS.md, scripts/.

# Файлы в корне (не внутри пакетов)
/*.txt
/*.json
/*.pdf
/*.psd
/*.cdr
/*.xlsx

# Локальные заметки
SCRATCH.md
TODO_PRIVATE.md

# Секреты
.env
.env.*
**/secrets/
expansion_app/android/key.properties
expansion_app/android/app/upload-keystore.jks
expansion_app/android/app/*.jks

# Node
expansion_server/node_modules/
**/node_modules/

# Flutter / Dart
**/.dart_tool/
**/.pub-cache/
**/.pub/
**/build/
**/coverage/

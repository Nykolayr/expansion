  "battleTutorialDragTitle": "Send a fleet",
  "battleTutorialDragBody": "Swipe from your base (blue) to a target. Half the ships on the base will launch.",
  "battleTutorialCaptureTitle": "Capture",
  "battleTutorialCaptureBody": "Watch the field: your fleet flies to the target (pulsing ring). After capture, tap the captured base.",
  "battleTutorialUpgradeTitle": "Base upgrades",
  "battleTutorialUpgradeBody": "Tap the captured base on the field. Buy an upgrade or tap Got it — next we explain the enemy and the battle goal.",
  "battleTutorialGoalTitle": "Battle goal",
  "battleTutorialGoalBody": "Red enemy bases also send fleets and capture your and neutral bases. Win by taking all enemy bases. You lose if you lose all your bases.",
  "battleTutorialDismiss": "Got it",
  "battleTutorialSkip": "Skip",
  "battleIntroMediumBaseTitle": "Medium base",
  "battleIntroMediumBaseBody": "Starts with 40 ships, cap 50. Harder to capture than small (20/30).",
  "battleIntroLargeBaseTitle": "Large base",
  "battleIntroLargeBaseBody": "Starts with 60 ships, cap 80. Capture last — send a large fleet.",
  "battleIntroRichBaseTitle": "Rich base",
  "battleIntroRichBaseBody": "5× resource income. Capture for upgrades. Don't send attack fleets from here — keep it as a rear base.",
  "battleIntroShieldedBaseTitle": "Shielded base",
  "battleIntroShieldedBaseBody": "Starts with a shield that absorbs hazard damage. Break the shield before destroying ships.",
  "battleIntroFactoryBaseTitle": "Factory base",
  "battleIntroFactoryBaseBody": "Builds ships 5× faster (×5) but starts with fewer. Hold it and production ramps up quickly.",
  "battleIntroBunkerBaseTitle": "Bunker base",
  "battleIntroBunkerBaseBody": "High ship cap and tough garrison, slower growth. Hard to crack — send a large fleet.",
  "battleIntroCometTitle": "Comet!",
  "battleIntroCometBody": "A comet sweeps in on an arc from a field corner. It hits bases and fleets in its path — watch for unpredictable trajectories.",
  "battleIntroPulseTitle": "Energy pulse!",
  "battleIntroPulseBody": "A pulse spreads from the center in a cross pattern. Hits bases and fleets on those lines — plan routes carefully.",
  "battleIntroDroneTitle": "Supply drones",
  "battleIntroDroneBody": "Periodically reinforce enemy bases with free ships. Pressure enemy bases before drones stack up.",
  "battleIntroSmallBaseTitle": "Small base",
  "battleIntroSmallBaseBody": "Starts with 20 ships, cap 30. Easiest to capture — good for the first expansions.",
  "battleIntroMineTitle": "Space mines",
  "battleIntroMineBody": "Mines sit on fixed cells and detonate when a fleet crosses them. Scout routes before sending a large attack.",
  "battleIntroSolarWindTitle": "Solar wind",
  "battleIntroSolarWindBody": "A wave sweeps across a whole row of the grid. Hits every base and fleet on that line — time your launches.",
  "battleIntroWormholeTitle": "Wormhole",
  "battleIntroWormholeBody": "Teleports crossing fleets to another point on the field. A shortcut with risk — sometimes a longer path is safer.",
  "battleDebrisTutorialTitle": "Meteor stream!",
  "battleDebrisTutorialBody": "A meteor stream crosses the center of the field. Destroys 80% of fleet and garrison ships in its path and keeps moving — don't route ships through the center unless you must.",
